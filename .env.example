# ── ANTP Environment Variables ──
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# TURN server credentials (get free from https://www.metered.ca/tools/openrelay/)
NEXT_PUBLIC_TURN_URL=turn:openrelay.metered.ca:80
NEXT_PUBLIC_TURN_USERNAME=openrelayproject
NEXT_PUBLIC_TURN_CREDENTIAL=openrelayproject

# Optional: Port override (default 3000)
# PORT=3000
