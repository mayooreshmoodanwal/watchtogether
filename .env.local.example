# ─── ANTP Environment Variables ───────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# TURN server credentials (Metered.ca — free tier)
# Sign up at https://www.metered.ca/ → Create Application → copy credentials
NEXT_PUBLIC_TURN_URL=turn:openrelay.metered.ca:80
NEXT_PUBLIC_TURN_USERNAME=your_turn_username
NEXT_PUBLIC_TURN_CREDENTIAL=your_turn_credential

# Optional: port override (default 3000)
# PORT=3000
