{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "app/**",
          "components/**",
          "lib/**",
          "public/**",
          "next.config.js",
          "tsconfig.json",
          "package.json",
          ".next/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
